# Secrets — NEVER commit
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Project data — large/generated, don't commit
data/pdfs/*.pdf
data/images/*
data/chromadb/*
data/*_elements.json
data/*_summaries.json
ingestion/*_summaries.json

# Keep the empty data dirs in git
!data/pdfs/.gitkeep
!data/images/.gitkeep
!data/chromadb/.gitkeep

# OS / editor
.DS_Store
.vscode/
.idea/
