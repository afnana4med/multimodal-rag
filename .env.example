# Copy this file to ".env" and fill in keys IF you have them.
# .env is gitignored — never commit real keys.
#
# IMPORTANT: keys are OPTIONAL. With no keys, the system runs fully free/local:
#   embeddings -> sentence-transformers (on-device)
#   vision     -> tesseract OCR
#   synthesis  -> extractive (returns best retrieved passages)
# Add a key and the matching stage automatically upgrades — no code changes.

# ---- API keys (optional) ----
# Enables OpenAI embeddings (text-embedding-3-small) and GPT-4o vision/synthesis.
# OPENAI_API_KEY=sk-...
# Enables Claude vision summarization + answer synthesis (preferred when set).
# ANTHROPIC_API_KEY=sk-ant-...

# ---- Provider overrides (optional — auto-detected from keys above) ----
# EMBEDDING_PROVIDER=local        # "openai" or "local"
# VISION_PROVIDER=ocr             # "anthropic", "openai", or "ocr"
# SYNTHESIS_PROVIDER=extractive   # "anthropic", "openai", or "extractive"

# ---- Model overrides (optional) ----
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5    # local default; openai default is text-embedding-3-small
# ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
# OPENAI_VISION_MODEL=gpt-4o
# ANTHROPIC_SYNTHESIS_MODEL=claude-sonnet-4-6
# OPENAI_SYNTHESIS_MODEL=gpt-4o

# ---- Parsing / chunking knobs (optional) ----
# MIN_IMAGE_WIDTH=100
# MIN_IMAGE_HEIGHT=100
# CHUNK_SIZE=512
# CHUNK_OVERLAP=50
# COLLECTION_NAME=multimodal_rag
